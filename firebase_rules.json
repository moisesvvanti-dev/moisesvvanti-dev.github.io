{
    "rules": {
        ".read": true,
        "users": {
            "$uid": {
                ".write": "auth != null && auth.uid === $uid",
                ".read": true
            }
        },
        "servers": {
            ".write": "auth != null",
            ".read": true,
            "$serverId": {
                "channels": {
                    "$channelId": {
                        "messages": {
                            ".write": "auth != null",
                            ".indexOn": [
                                "time"
                            ]
                        }
                    }
                },
                "members": {
                    ".write": "auth != null"
                },
                "pinnedMessages": {
                    ".write": "auth != null"
                },
                "settings": {
                    ".write": "auth != null"
                }
            }
        },
        "forums": {
            ".write": "auth != null",
            ".read": true,
            ".indexOn": [
                "time"
            ]
        },
        "voice_rooms": {
            ".write": "auth != null",
            ".read": true,
            "$roomId": {
                "participants": {
                    ".write": "auth != null",
                    "$uid": {
                        ".write": "auth != null"
                    }
                },
                "audio_chunks": {
                    ".write": "auth != null",
                    "$uid": {
                        ".write": "auth != null && auth.uid === $uid"
                    }
                }
            }
        },
        "friendships": {
            ".write": "auth != null",
            ".read": "auth != null",
            "$friendshipId": {
                ".write": "auth != null"
            }
        },
        "friend_requests": {
            ".write": "auth != null",
            ".read": "auth != null",
            "$requestId": {
                ".write": "auth != null"
            }
        },
        "blocked_users": {
            "$uid": {
                ".write": "auth != null && auth.uid === $uid",
                ".read": "auth != null && auth.uid === $uid"
            }
        },
        "direct_messages": {
            ".write": "auth != null",
            ".read": "auth != null",
            "$chatId": {
                ".write": "auth != null",
                ".indexOn": [
                    "time"
                ]
            }
        },
        "groups": {
            ".write": "auth != null",
            ".read": "auth != null",
            "$groupId": {
                "messages": {
                    ".write": "auth != null",
                    ".indexOn": [
                        "time"
                    ]
                }
            }
        },
        "global_notifications": {
            ".write": "auth != null",
            ".read": true,
            ".indexOn": [
                "time"
            ]
        },
        "file_shares": {
            ".write": "auth != null",
            ".read": true,
            "$fileId": {
                ".write": "auth != null"
            }
        },
        "user_settings": {
            "$uid": {
                ".write": "auth != null && auth.uid === $uid",
                ".read": "auth != null && auth.uid === $uid"
            }
        },
        "presence": {
            ".write": "auth != null",
            ".read": true,
            "$uid": {
                ".write": "auth != null && auth.uid === $uid"
            }
        },
        "typing_indicators": {
            ".write": "auth != null",
            ".read": true
        },
        "nicknames": {
            ".read": true,
            ".write": "auth != null"
        },
        "system_config": {
            ".read": true,
            ".write": "auth != null && auth.token.email === 'moisesvvanti@gmail.com'"
        },
        "changelog": {
            ".read": true,
            ".write": "auth != null && auth.token.email === 'moisesvvanti@gmail.com'",
            ".indexOn": [
                "timestamp"
            ]
        },
        "popular_stats": {
            ".read": true,
            "$week_id": {
                "$tool_id": {
                    ".write": "auth != null || !data.exists() || newData.val() > data.val()",
                    ".validate": "newData.isNumber()"
                }
            }
        },
        "search_activity": {
            ".read": true,
            ".write": true,
            "$entry_id": {
                ".validate": "newData.hasChildren(['query', 'timestamp'])"
            }
        },
        "access_logs": {
            ".read": "auth != null && auth.token.email === 'moisesvvanti@gmail.com'",
            ".write": true,
            "$entry_id": {
                ".validate": "newData.hasChildren(['timestamp', 'userAgent'])"
            }
        },
        "discovery_queue": {
            ".read": true,
            ".write": true,
            "$entry_id": {
                ".validate": "newData.isString()"
            }
        },
        "discovery_history": {
            ".read": true,
            ".write": true
        },
        "bug_reports": {
            ".read": "auth != null && auth.token.email === 'moisesvvanti@gmail.com'",
            ".write": true,
            "$report_id": {
                ".validate": "newData.hasChildren(['type', 'description', 'timestamp']) && newData.child('description').val().length < 2000 && newData.child('type').val().length < 50 && newData.child('page').val().length < 100 && newData.child('timestamp').val() <= now"
            }
        },
        "supporters": {
            ".read": true,
            ".write": "auth != null",
            ".indexOn": [
                "total_amount"
            ]
        },
        "message_reports": {
            ".write": "auth != null",
            ".read": "auth != null && auth.token.email === 'moisesvvanti@gmail.com'",
            ".indexOn": [
                "timestamp"
            ]
        },
        "tools": {
            ".read": true,
            ".write": "auth != null"
        },
        "admin_actions": {
            ".read": "auth != null && auth.token.email === 'moisesvvanti@gmail.com'",
            ".write": "auth != null && auth.token.email === 'moisesvvanti@gmail.com'"
        }
    }
}